# BusRadar realtime-spike placeholders.
# Do not commit real keys or private feed URLs.

# Path to an extracted, authorized GTFS static folder containing routes.txt,
# trips.txt, shapes.txt, stops.txt and stop_times.txt.
GTFS_STATIC_DIR=

# Future GTFS-Realtime feeds. Keep empty until feed access and license are verified.
GTFS_RT_VEHICLE_POSITIONS_URL=
GTFS_RT_TRIP_UPDATES_URL=
GTFS_RT_ALERTS_URL=
GTFS_RT_API_KEY=

# Adapter remains disabled by default. The production UI still uses SimulationAdapter.
VITE_TRANSIT_DATA_MODE=simulation
